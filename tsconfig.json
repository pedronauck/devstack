{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "strict": true,
        "noEmit": true,
        "allowImportingTsExtensions": true,
        "verbatimModuleSyntax": true,
        "skipLibCheck": true,
        "types": ["node"]
    },
    "include": ["bin/**/*.ts", "src/**/*.ts", "tests/**/*.ts"]
}
